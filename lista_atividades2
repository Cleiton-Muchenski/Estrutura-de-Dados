}

void imprimirMenoresX(float x){
    int i;
    int achou = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] != 0 && salarios[i] < x) {
            printf("[%i] = R$ %.2f\n", i, salarios[i]);
            achou = 1;
        }
    }
    if (achou == 0) printf("Nenhum salario menor que %.2f encontrado.\n", x);
}

void aplicarAcrescimo(float z){
    int i;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] != 0) {
            salarios[i] = salarios[i] + (salarios[i] * (z / 100));
        }
    }
    printf("Acrescimo de %.2f%% aplicado!\n", z);
}

void aplicarDesconto(float z, float x){
    int i;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] > x) {
            salarios[i] = salarios[i] - (salarios[i] * (z / 100));
        }
    }
    printf("Desconto de %.2f%% aplicado!\n", z);
}

