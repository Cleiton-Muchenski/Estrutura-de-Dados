    int cont = 0;
    for (int i = 0; i < TAM; i++) {
        if (idades[i] != 0) {
            cont++;
        }
    }
    printf("Total de idades: %i\n", cont);
}

void somar(){
    int soma = 0;
    for (int i = 0; i < TAM; i++) {
        soma += idades[i];
    }
    printf("Soma das idades: %i\n", soma);
}

void somarImpares(){
    int soma = 0;
    for (int i = 0; i < TAM; i++) {
        if (idades[i] % 2 != 0) {
            soma += idades[i];
        }
    }
    printf("Soma das idades ímpares: %i\n", soma);
}

