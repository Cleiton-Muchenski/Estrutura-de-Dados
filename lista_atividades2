    printf("Lista cheia!\n");
}

void adicionarPos(int idade, int pos){
    if (pos < 0 || pos >= TAM) {
        printf("Posição inválida!\n");
    } else if (idades[pos] != 0) {
        printf("Posição ocupada!\n");
    } else {
        idades[pos] = idade;
        printf("Idade %i adicionada na posição %i\n", idade, pos);
