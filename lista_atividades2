#define TAM 100

float salarios[TAM] = {0};

void adicionar(float valor){
    int i;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] == 0) {
            salarios[i] = valor;
            printf("Salario R$ %.2f adicionado na posicao %i\n", valor, i);
            return;
        }
    }
    printf("Lista cheia!\n");
}

void removerPos(int pos){
    if (pos < 0 || pos >= TAM) {
        printf("Posicao invalida!\n");
    } else if (salarios[pos] == 0) {
        printf("Nada para remover!\n");
    } else {
        printf("Salario R$ %.2f removido da posicao %i\n", salarios[pos], pos);
        salarios[pos] = 0;
    }
}

void imprimirTodos(){
    int i;
    int vazio = 1;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] != 0) {
            printf("[%i] = R$ %.2f\n", i, salarios[i]);
            vazio = 0;
        }
    }
    if (vazio == 1) printf("Lista vazia!\n");
}

void pesquisarSalario(float x){
    int i;
    int achou = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] == x) {
            printf("Salario %.2f encontrado na posicao %i\n", x, i);
            achou = 1;
        }
    }
    if (achou == 0) printf("Salario nao encontrado!\n");
}

void adicionarPos(float valor, int pos){
    if (pos < 0 || pos >= TAM) {
        printf("Posicao invalida!\n");
    } else if (salarios[pos] != 0) {
        printf("Posicao ocupada!\n");
    } else {
        salarios[pos] = valor;
        printf("Salario R$ %.2f adicionado na posicao %i\n", valor, pos);
    }
}

void contarQuantX(float x){
    int i;
    int cont = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] == x) {
            cont++;
        }
    }
    printf("O salario %.2f aparece %i vezes no vetor\n", x, cont);
}

void somarTudo(){
    int i;
    float soma = 0;
    for (i = 0; i < TAM; i++) {
        soma = soma + salarios[i];
    }
    printf("Soma de todos os salarios: R$ %.2f\n", soma);
}

void somarX(float x){
    int i;
    float soma = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] == x) {
            soma = soma + salarios[i];
        }
    }
    printf("Soma dos salarios iguais a %.2f: R$ %.2f\n", x, soma);
}

void contarTudo(){
    int i;
    int cont = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] != 0) {
            cont++;
        }
    }
    printf("Total de salarios no vetor: %i\n", cont);
}

void contarMaioresX(float x){
    int i;
    int cont = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] > x) {
            cont++;
        }
    }
    printf("Existem %i salarios maiores que %.2f\n", cont, x);
}

void maiorSalario(){
    int i;
    float maior = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] > maior) {
            maior = salarios[i];
        }
    }
    printf("Maior salario encontrado: R$ %.2f\n", maior);
}

void menorSalario(){
    int i;
    float menor = -1;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] != 0) {
            if (menor == -1 || salarios[i] < menor) {
                menor = salarios[i];
            }
        }
    }
    if (menor == -1) printf("Vetor vazio!\n");
    else printf("Menor salario encontrado: R$ %.2f\n", menor);
}

void media(){
    int i;
    int cont = 0;
    float soma = 0;
    for (i = 0; i < TAM; i++) {
        if (salarios[i] != 0) {
            soma = soma + salarios[i];
            cont++;
        }
    }
    if (cont > 0) printf("Media dos salarios: R$ %.2f\n", soma / cont);
    else printf("Nao ha salarios para calcular media!\n");
}

void removerValorX(float x){
    int i;
