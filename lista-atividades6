#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Livro {
    int codigo;
    char nome[50];
    char classificacao[30];
    float preco;
    struct Livro *ant;
    struct Livro *prox;
};

struct Lista {
    struct Livro *ini;
    struct Livro *fim;
};

void criar(struct Lista *l) {
    l->ini = NULL;
    l->fim = NULL;
}

int vazia(struct Lista *l) {
    if (l->ini == NULL) return 1;
    else return 0;
}

void add_inicio(struct Lista *l) {
    struct Livro *novo = (struct Livro*) malloc(sizeof(struct Livro));
    printf("Codigo: "); scanf("%d", &novo->codigo);
    printf("Nome: "); scanf("%s", novo->nome);
    printf("Classificacao: "); scanf("%s", novo->classificacao);
    printf("Preco: "); scanf("%f", &novo->preco);
    
    novo->ant = NULL;
    novo->prox = l->ini;

    if (vazia(l) == 1) {
        l->fim = novo;
    } else {
        l->ini->ant = novo;
    }
    l->ini = novo;
}

void add_final(struct Lista *l) {
    struct Livro *novo = (struct Livro*) malloc(sizeof(struct Livro));
    printf("Codigo: "); scanf("%d", &novo->codigo);
    printf("Nome: "); scanf("%s", novo->nome);
    printf("Classificacao: "); scanf("%s", novo->classificacao);
    printf("Preco: "); scanf("%f", &novo->preco);
    
    novo->prox = NULL;
    novo->ant = l->fim;

    if (vazia(l) == 1) {
        l->ini = novo;
    } else {
        l->fim->prox = novo;
    }
    l->fim = novo;
}

void add_depois(struct Lista *l) {
    if (vazia(l) == 1) return;
    int cod;
    printf("Adicionar apos qual codigo? "); scanf("%d", &cod);
    struct Livro *aux = l->ini;
    while (aux != NULL && aux->codigo != cod) aux = aux->prox;

    if (aux != NULL) {
        struct Livro *novo = (struct Livro*) malloc(sizeof(struct Livro));
        printf("Codigo: "); scanf("%d", &novo->codigo);
        printf("Nome: "); scanf("%s", novo->nome);
        printf("Classificacao: "); scanf("%s", novo->classificacao);
        printf("Preco: "); scanf("%f", &novo->preco);

        novo->prox = aux->prox;
        novo->ant = aux;
        if (aux->prox == NULL) l->fim = novo;
        else aux->prox->ant = novo;
        aux->prox = novo;
    }
}

void remover_cod(struct Lista *l) {
    if (vazia(l) == 1) return;
    int cod;
    printf("Remover qual codigo? "); scanf("%d", &cod);
    struct Livro *aux = l->ini;
    while (aux != NULL && aux->codigo != cod) aux = aux->prox;

    if (aux != NULL) {
        if (aux->ant == NULL) l->ini = aux->prox;
        else aux->ant->prox = aux->prox;

        if (aux->prox == NULL) l->fim = aux->ant;
        else aux->prox->ant = aux->ant;

        free(aux);
        printf("Removido!\n");
    }
}

void imprimir_IF(struct Lista *l) {
    struct Livro *aux = l->ini;
    while (aux != NULL) {
        printf("[%d | %s | %.2f]\n", aux->codigo, aux->nome, aux->preco);
        aux = aux->prox;
    }
}

void imprimir_FI(struct Lista *l) {
    struct Livro *aux = l->fim;
    while (aux != NULL) {
        printf("[%d | %s | %.2f]\n", aux->codigo, aux->nome, aux->preco);
        aux = aux->ant;
    }
}

void media(struct Lista *l) {
    if (vazia(l) == 1) return;
    float soma = 0;
    int c = 0;
    struct Livro *aux = l->ini;
    while (aux != NULL) {
        soma += aux->preco;
        c++;
        aux = aux->prox;
    }
    printf("Media: %.2f\n", soma / c);
}

void resumo_classificacao(struct Lista *l) {
    struct Livro *aux = l->ini;
    while (aux != NULL) {
        struct Livro *aux2 = l->ini;
        int ja_contou = 0;
        while (aux2 != aux) {
            if (strcmp(aux2->classificacao, aux->classificacao) == 0) {
                ja_contou = 1;
                break;
            }
            aux2 = aux2->prox;
        }
        if (ja_contou == 0) {
            int qtd = 0;
            float soma = 0;
            struct Livro *busca = l->ini;
            while (busca != NULL) {
                if (strcmp(busca->classificacao, aux->classificacao) == 0) {
                    qtd++;
                    soma += busca->preco;
                }
                busca = busca->prox;
            }
            printf("Class: %s | Qtd: %d | Soma: %.2f\n", aux->classificacao, qtd, soma);
        }
        aux = aux->prox;
    }
}

void menu(struct Lista *l) {
    int opc;
    do {
        printf("\n1-Add Inicio\n2-Add Final\n3-Add Apos Cod\n4-Remover Cod\n5-Imprimir IF\n6-Imprimir FI\n7-Media\n8-Resumo Classificacao\n9-Sair\nOpcao: ");
        scanf("%d", &opc);
        if (opc == 1) add_inicio(l);
        else if (opc == 2) add_final(l);
        else if (opc == 3) add_depois(l);
        else if (opc == 4) remover_cod(l);
        else if (opc == 5) imprimir_IF(l);
        else if (opc == 6) imprimir_FI(l);
        else if (opc == 7) media(l);
        else if (opc == 8) resumo_classificacao(l);
    } while (opc != 9);
}

int main() {
    struct Lista lista;
    criar(&lista);
    menu(&lista);
    return 0;
}

