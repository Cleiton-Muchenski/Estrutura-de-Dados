#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Cliente {
    char cpf[15];
    char agencia[10];
    char conta[15];
    char tipo[20];
    char nome[50];
    struct Cliente *ant;
    struct Cliente *prox;
};

struct FilaBanco {
    struct Cliente *ini;
    struct Cliente *fim;
    int total_atendidos;
    int total_inclusos;
};

void criar(struct FilaBanco *f) {
    f->ini = NULL;
    f->fim = NULL;
    f->total_atendidos = 0;
    f->total_inclusos = 0;
}

int vazia(struct FilaBanco *f) {
    if (f->ini == NULL) return 1;
    else return 0;
}

int cpf_existe(struct FilaBanco *f, char c[]) {
    struct Cliente *aux = f->ini;
    while (aux != NULL) {
        if (strcmp(aux->cpf, c) == 0) return 1;
        aux = aux->prox;
    }
    return 0;
}

void preencher_dados(struct Cliente *novo, struct FilaBanco *f) {
    printf("CPF: "); scanf("%s", novo->cpf);
    if (cpf_existe(f, novo->cpf)) {
        printf("Erro: CPF ja existe!\n");
        free(novo);
        return;
    }
    printf("Agencia: "); scanf("%s", novo->agencia);
    printf("Conta: "); scanf("%s", novo->conta);
    printf("Tipo (DEPOSITO, PAGTO, SAQUE): "); scanf("%s", novo->tipo);
    printf("Nome: "); scanf("%s", novo->nome);
    f->total_inclusos++;
}

void add_inicio(struct FilaBanco *f) {
    struct Cliente *novo = (struct Cliente*) malloc(sizeof(struct Cliente));
    printf("CPF: "); scanf("%s", novo->cpf);
    if (cpf_existe(f, novo->cpf)) {
        printf("CPF Duplicado!\n");
        free(novo);
        return;
    }
    printf("Agencia: "); scanf("%s", novo->agencia);
    printf("Conta: "); scanf("%s", novo->conta);
    printf("Tipo: "); scanf("%s", novo->tipo);
    printf("Nome: "); scanf("%s", novo->nome);

    novo->ant = NULL;
    novo->prox = f->ini;
    if (vazia(f)) f->fim = novo;
    else f->ini->ant = novo;
    f->ini = novo;
    f->total_inclusos++;
}

void add_final(struct FilaBanco *f) {
    struct Cliente *novo = (struct Cliente*) malloc(sizeof(struct Cliente));
    printf("CPF: "); scanf("%s", novo->cpf);
    if (cpf_existe(f, novo->cpf)) {
        printf("CPF Duplicado!\n");
        free(novo);
        return;
    }
    printf("Agencia: "); scanf("%s", novo->agencia);
    printf("Conta: "); scanf("%s", novo->conta);
    printf("Tipo: "); scanf("%s", novo->tipo);
    printf("Nome: "); scanf("%s", novo->nome);

    novo->prox = NULL;
    novo->ant = f->fim;
    if (vazia(f)) f->ini = novo;
    else f->fim->prox = novo;
    f->fim = novo;
    f->total_inclusos++;
}

void remover_inicio(struct FilaBanco *f) {
    if (vazia(f)) return;
    struct Cliente *aux = f->ini;
    f->ini = f->ini->prox;
    if (f->ini == NULL) f->fim = NULL;
    else f->ini->ant = NULL;
    free(aux);
    f->total_atendidos++;
}

void imprimir_avante(struct FilaBanco *f) {
    struct Cliente *aux = f->ini;
    while (aux != NULL) {
        printf("[%s | %s | %s]\n", aux->nome, aux->cpf, aux->tipo);
        aux = aux->prox;
    }
}

void imprimir_atras(struct FilaBanco *f) {
    struct Cliente *aux = f->fim;
    while (aux != NULL) {
        printf("[%s | %s | %s]\n", aux->nome, aux->cpf, aux->tipo);
        aux = aux->ant;
    }
}

void vizinhos(struct FilaBanco *f) {
    char c[15];
    printf("Digite o CPF: "); scanf("%s", c);
    struct Cliente *aux = f->ini;
    while (aux != NULL && strcmp(aux->cpf, c) != 0) aux = aux->prox;
    
    if (aux != NULL) {
        if (aux->ant != NULL) printf("Anterior: %s\n", aux->ant->nome);
        else printf("Nao tem anterior (Início)\n");
        
        if (aux->prox != NULL) printf("Proximo: %s\n", aux->prox->nome);
        else printf("Nao tem proximo (Final)\n");
    }
}

void resumo_tipos(struct FilaBanco *f) {
    int d = 0, p = 0, s = 0;
    struct Cliente *aux = f->ini;
    while (aux != NULL) {
        if (strcmp(aux->tipo, "DEPOSITO") == 0) d++;
        else if (strcmp(aux->tipo, "PAGTO") == 0) p++;
        else if (strcmp(aux->tipo, "SAQUE") == 0) s++;
        aux = aux->prox;
    }
    printf("DEPOSITO: %d | PAGTO: %d | SAQUE: %d\n", d, p, s);
}

void menu(struct FilaBanco *f) {
    int opc;
    do {
        printf("\n1-Add Inicio\n2-Add Final\n4-Remover Inicio\n7-Listar ->\n8-Listar <-\n12-Atendidos\n13-Total Inclusos\n14-Vizinhos\n15-Resumo Tipos\n9-Sair\nOpcao: ");
        scanf("%d", &opc);
        if (opc == 1) add_inicio(f);
        else if (opc == 2) add_final(f);
        else if (opc == 4) remover_inicio(f);
        else if (opc == 7) imprimir_avante(f);
        else if (opc == 8) imprimir_atras(f);
        else if (opc == 12) printf("Atendidos: %d\n", f->total_atendidos);
        else if (opc == 13) printf("Inclusos: %d\n", f->total_inclusos);
        else if (opc == 14) vizinhos(f);
        else if (opc == 15) resumo_tipos(f);
    } while (opc != 9);
}

int main() {
    struct FilaBanco fila;
    criar(&fila);
    menu(&fila);
    return 0;
}
