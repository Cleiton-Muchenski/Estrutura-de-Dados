#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define TAM 10

typedef struct Veiculo {
    char placa[10];
    char nomeMotorista[50];
    float totalPedido;
} Veiculo;

Veiculo fila[TAM];
int inicio = 0;
int fim = 0;
int quantidade = 0;

void adicionar(Veiculo v) {
    if (quantidade < TAM) {
        fila[fim] = v;
        
        fim = fim + 1;
        if (fim == TAM) {
            fim = 0; 
        }
        
        quantidade = quantidade + 1;
        printf("Veiculo placa %s adicionado na fila do drive thru!\n", v.placa);
    } else {
        printf("Fila cheia! Limite de 10 veiculos atingido.\n");
    }
}

void atender() {
    if (quantidade > 0) {
        printf("Atendendo veiculo placa %s (Motorista: %s)\n", fila[inicio].placa, fila[inicio].nomeMotorista);
        
        inicio = inicio + 1;
        if (inicio == TAM) {
            inicio = 0; 
        }
        
        quantidade = quantidade - 1;
    } else {
        printf("Nao ha veiculos na fila para atender.\n");
    }
}

void veiculosNaFila() {
    int i;
    int pos;
    
    if (quantidade == 0) {
        printf("Fila vazia!\n");
    } else {
        printf("\n--- VEICULOS NA FILA ---\n");
        pos = inicio;
        for (i = 0; i < quantidade; i++) {
            printf("[%i] Placa: %s | Motorista: %s\n", i + 1, fila[pos].placa, fila[pos].nomeMotorista);
            
            pos = pos + 1;
            if (pos == TAM) {
                pos = 0;
            }
        }
        printf("------------------------\n");
    }
}

void numeroVeiculosParaAtender() {
    printf("Numero de veiculos aguardando na fila: %i\n", quantidade);
}

void pesquisar(char placaBusca[]) {
    int i;
    int pos;
    int achou = 0;
    
    pos = inicio;
    for (i = 0; i < quantidade; i++) {
        if (strcmp(fila[pos].placa, placaBusca) == 0) {
            printf("Veiculo encontrado na posicao %i da fila!\n", i + 1);
            printf("Motorista: %s | Total Pedido: R$ %.2f\n", fila[pos].nomeMotorista, fila[pos].totalPedido);
            achou = 1;
        }
        
        pos = pos + 1;
        if (pos == TAM) {
            pos = 0;
        }
    }
    
    if (achou == 0) {
        printf("Veiculo com placa %s nao encontrado na fila.\n", placaBusca);
    }
}

void menu() {
    int opc;
    char buscaPlaca[10];
    Veiculo novo;

    do {
        printf("\n**************************************************\n");
        printf("MENU - DRIVE THRU\n");
        printf("1 - Adicionar (Adicionar um veiculo na fila)\n");
        printf("2 - Atender (Remover um veiculo da fila)\n");
        printf("3 - Veiculos na Fila (Exibir placa e motorista)\n");
        printf("4 - Numero de Veiculos para Atender (Exibir total)\n");
        printf("5 - Pesquisar (Verificar placa na fila)\n");
        printf("99 - Sair\n");
        printf("**************************************************\n");
        printf("Digite a opcao desejada: ");
        scanf("%i", &opc);

        if (opc == 1) {
            printf("Digite a placa: "); scanf(" %s", novo.placa);
            printf("Nome do Motorista: "); scanf(" %[^\n]s", novo.nomeMotorista);
            printf("Total do Pedido: "); scanf("%f", &novo.totalPedido);
            adicionar(novo);
        } else if (opc == 2) {
            atender();
        } else if (opc == 3) {
            veiculosNaFila();
        } else if (opc == 4) {
            numeroVeiculosParaAtender();
        } else if (opc == 5) {
            printf("Digite a placa para pesquisar: "); scanf(" %s", buscaPlaca);
            pesquisar(buscaPlaca);
        }

    } while (opc != 99);
}

int main() {
    menu();
    return 0;
}

