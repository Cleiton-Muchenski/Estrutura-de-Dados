#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Veiculo {
    int codigo;
    char placa[20];
    char modelo[50];
    char marca[50];
    float preco;
    struct Veiculo *prox;
};

struct Fila {
    struct Veiculo *ini;
    struct Veiculo *fim;
};

void criar(struct Fila *f) {
    f->ini = NULL;
    f->fim = NULL;
}

int vazia(struct Fila *f) {
    if (f->ini == NULL) {
        return 1;
    } else {
        return 0;
    }
}

void enfileirar(struct Fila *f) {
    struct Veiculo *novo = (struct Veiculo*) malloc(sizeof(struct Veiculo));
    if (novo == NULL) {
        printf("erro\n");
    } else {
        printf("Codigo: ");
        scanf("%d", &novo->codigo);
        printf("Placa: ");
        scanf("%s", novo->placa);
        printf("Modelo: ");
        scanf("%s", novo->modelo);
        printf("Marca: ");
        scanf("%s", novo->marca);
        printf("Preco: ");
        scanf("%f", &novo->preco);
        
        novo->prox = NULL;

        if (vazia(f) == 1) {
            f->ini = novo;
            f->fim = novo;
        } else {
            f->fim->prox = novo;
            f->fim = novo;
        }
    }
}

void desenfileirar(struct Fila *f) {
    if (vazia(f) == 1) {
        printf("Fila vazia\n");
    } else {
        struct Veiculo *aux = f->ini;
        f->ini = f->ini->prox;
        if (f->ini == NULL) {
            f->fim = NULL;
        }
        free(aux);
        printf("Removido!\n");
    }
}

void relatorio(struct Fila *f) {
    if (vazia(f) == 1) {
        printf("Vazia\n");
    } else {
        struct Veiculo *atual = f->ini;
        while (atual != NULL) {
            printf("Cod: %d | Placa: %s | Modelo: %s | Preco: %.2f\n", atual->codigo, atual->placa, atual->modelo, atual->preco);
            atual = atual->prox;
        }
    }
}

void inicio(struct Fila *f) {
    if (vazia(f) == 1) {
        printf("Vazia\n");
    } else {
        printf("Primeiro: %s - %s\n", f->ini->placa, f->ini->modelo);
    }
}

void final(struct Fila *f) {
    if (vazia(f) == 1) {
        printf("Vazia\n");
    } else {
        printf("Ultimo: %s - %s\n", f->fim->placa, f->fim->modelo);
    }
}

void total(struct Fila *f) {
    int cont = 0;
    struct Veiculo *aux = f->ini;
    while (aux != NULL) {
        cont++;
        aux = aux->prox;
    }
    printf("Total de veiculos: %d\n", cont);
}

void localizar(struct Fila *f) {
    if (vazia(f) == 1) {
        printf("Vazia\n");
    } else {
        char p[20];
        printf("Placa para buscar: ");
        scanf("%s", p);
        struct Veiculo *aux = f->ini;
        int achou = 0;
        while (aux != NULL) {
            if (strcmp(aux->placa, p) == 0) {
                printf("Localizado! Modelo: %s | Marca: %s\n", aux->modelo, aux->marca);
                achou = 1;
                break;
            }
            aux = aux->prox;
        }
        if (achou == 0) printf("Placa nao encontrada\n");
    }
}

void mais_caro(struct Fila *f) {
    if (vazia(f) == 1) {
        printf("Vazia\n");
    } else {
        struct Veiculo *aux = f->ini;
        struct Veiculo *caro = f->ini;
        float maior = f->ini->preco;
        while (aux != NULL) {
            if (aux->preco > maior) {
                maior = aux->preco;
                caro = aux;
            }
            aux = aux->prox;
        }
        printf("Mais caro: %s por %.2f\n", caro->modelo, caro->preco);
    }
}

void menu(struct Fila *f) {
    int opc;
    do {
        printf("\n1-Enfileirar\n2-Desenfileirar\n3-Relatorio\n4-Inicio\n5-Final\n6-Total\n7-Localizar\n8-Mais Caro\n9-Sair\nOpcao: ");
        scanf("%d", &opc);
        if (opc == 1) enfileirar(f);
        else if (opc == 2) desenfileirar(f);
        else if (opc == 3) relatorio(f);
        else if (opc == 4) inicio(f);
        else if (opc == 5) final(f);
        else if (opc == 6) total(f);
        else if (opc == 7) localizar(f);
        else if (opc == 8) mais_caro(f);
    } while (opc != 9);
}

int main() {
    struct Fila f1;
    criar(&f1);
    menu(&f1);
    return 0;
}

