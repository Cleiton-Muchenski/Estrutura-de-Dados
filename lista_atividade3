#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define TAM 100

typedef struct {
    int codigo;
    char titulo[50];
    float preco;
} Livro;

Livro pilha[TAM];
int topo = -1;

void empilhar(Livro liv) {
    if (topo < TAM - 1) {
        topo++;
        pilha[topo] = liv;
        printf("Livro '%s' empilhado!\n", liv.titulo);
    } else {
        printf("Erro: A pilha esta cheia!\n");
    }
}

void desempilhar() {
    if (topo >= 0) {
        printf("Livro '%s' desempilhado!\n", pilha[topo].titulo);
        topo--;
    } else {
        printf("Erro: A pilha esta vazia!\n");
    }
}

void imprimir() {
    int i;
    if (topo == -1) {
        printf("Pilha vazia!\n");
    } else {
        printf("\n--- LIVROS NA PILHA ---\n");
        for (i = topo; i >= 0; i--) {
            printf("Posicao: %i | Codigo: %i | Titulo: %s | Preco: R$ %.2f\n", i, pilha[i].codigo, pilha[i].titulo, pilha[i].preco);
        }
        printf("------------------------\n");
    }
}

void menu() {
    int opc;
    Livro novoLivro;

    do {
        printf("\n****************************\n");
        printf("MENU\n");
        printf("1 - Empilhar\n");
        printf("2 - Desempilhar\n");
        printf("3 - Imprimir\n");
        printf("99 - Sair\n");
        printf("****************************\n");
        printf("Digite a opcao desejada: ");
        scanf("%i", &opc);

        if (opc == 1) {
            printf("Digite o codigo do livro: ");
            scanf("%i", &novoLivro.codigo);
            printf("Digite o titulo do livro: ");
            scanf(" %[^\n]s", novoLivro.titulo); 
            printf("Digite o preco do livro: ");
            scanf("%f", &novoLivro.preco);
            
            empilhar(novoLivro);
        } else if (opc == 2) {
            desempilhar();
        } else if (opc == 3) {
            imprimir();
        }

    } while (opc != 99);
}

int main() {
    menu();
    return 0;
}
